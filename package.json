{
  "name": "midi-studio",
  "version": "0.1.0",
  "description": "Open-source desktop MIDI practice studio built with React and Electron.",
  "license": "MIT",
  "author": "",
  "main": "dist/main/main.js",
  "keywords": [
    "midi",
    "electron",
    "react",
    "music",
    "numbered-notation"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173/index.html electron .",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "dist:dir": "npm run build && electron-builder --win dir",
    "dist:portable": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "validate:score-fixtures": "node scripts/validate-score-fixtures.mjs",
    "validate:musicxml-fixtures": "node scripts/validate-musicxml-fixtures.mjs"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "@xmldom/xmldom": "^0.9.10",
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^18.19.120",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^25.9.8",
    "electron-builder": "^24.13.3",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.4.5",
    "vite": "^4.5.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.midistudio.app",
    "productName": "midi-studio",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "dist/renderer/soundfonts/**/*",
      "dist/renderer/vendor/alphasynth/**/*",
      "node_modules/sqlite3/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
